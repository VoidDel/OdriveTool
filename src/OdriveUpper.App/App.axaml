<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OdriveUpper.App.App"
             xmlns:local="using:OdriveUpper.App"
             RequestedThemeVariant="Default">
             <!-- Default to system theme, toggleable to Light/Dark -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PrimaryBackground">#F8FAFC</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarBackground">#F1F5F9</SolidColorBrush>
                    <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardHeaderBackground">#F8FAFC</SolidColorBrush>
                    <SolidColorBrush x:Key="BorderBrush">#E2E8F0</SolidColorBrush>
                    <SolidColorBrush x:Key="TextPrimary">#0F172A</SolidColorBrush>
                    <SolidColorBrush x:Key="TextSecondary">#64748B</SolidColorBrush>
                    <SolidColorBrush x:Key="TextMuted">#94A3B8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentColor">#0EA5E9</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentHoverColor">#0284C7</SolidColorBrush>
                    <SolidColorBrush x:Key="ChartAxis0Color">#0369A1</SolidColorBrush>
                    <SolidColorBrush x:Key="ChartAxis1Color">#B45309</SolidColorBrush>
                    <SolidColorBrush x:Key="StatusOk">#10B981</SolidColorBrush>
                    <SolidColorBrush x:Key="StatusWarning">#F59E0B</SolidColorBrush>
                    <SolidColorBrush x:Key="StatusError">#EF4444</SolidColorBrush>
                    <SolidColorBrush x:Key="ControlBackground">#E2E8F0</SolidColorBrush>
                    <SolidColorBrush x:Key="InputBackground">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="PanelBackground">#F1F5F9</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PrimaryBackground">#090D16</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarBackground">#0F131F</SolidColorBrush>
                    <SolidColorBrush x:Key="CardBackground">#141926</SolidColorBrush>
                    <SolidColorBrush x:Key="CardHeaderBackground">#1A2030</SolidColorBrush>
                    <SolidColorBrush x:Key="BorderBrush">#222A3F</SolidColorBrush>
                    <SolidColorBrush x:Key="TextPrimary">#F1F5F9</SolidColorBrush>
                    <SolidColorBrush x:Key="TextSecondary">#94A3B8</SolidColorBrush>
                    <SolidColorBrush x:Key="TextMuted">#475569</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentColor">#38BDF8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentHoverColor">#7DD3FC</SolidColorBrush>
                    <SolidColorBrush x:Key="ChartAxis0Color">#0284C7</SolidColorBrush>
                    <SolidColorBrush x:Key="ChartAxis1Color">#C2410C</SolidColorBrush>
                    <SolidColorBrush x:Key="StatusOk">#34D399</SolidColorBrush>
                    <SolidColorBrush x:Key="StatusWarning">#FBBF24</SolidColorBrush>
                    <SolidColorBrush x:Key="StatusError">#F87171</SolidColorBrush>
                    <SolidColorBrush x:Key="ControlBackground">#1E293B</SolidColorBrush>
                    <SolidColorBrush x:Key="InputBackground">#1A2030</SolidColorBrush>
                    <SolidColorBrush x:Key="PanelBackground">#0F131F</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>