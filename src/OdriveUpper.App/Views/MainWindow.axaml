<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OdriveUpper.App.ViewModels"
        xmlns:controls="using:OdriveUpper.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="780"
        x:Class="OdriveUpper.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Icon="/Assets/avalonia-logo.ico"
        Title="ODrive Custom Upper Computer"
        TransparencyLevelHint="Mica, AcrylicBlur, None"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="45"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="600">

    <Window.Styles>
        <!-- Base Button Style -->
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TextSecondary}"/>
        </Style>

        <!-- Nav Button Style -->
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style Selector="Button.nav:pointerover">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
        <Style Selector="Button.nav.active">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.nav.active TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- Accent Action Button -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentHoverColor}"/>
        </Style>

        <!-- Danger Button -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{DynamicResource StatusError}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Warning Button -->
        <Style Selector="Button.warning">
            <Setter Property="Background" Value="{DynamicResource StatusWarning}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.warning:pointerover">
            <Setter Property="Opacity" Value="0.85"/>
        </Style>

        <!-- Choice Buttons (Horizontal Card Style) -->
        <Style Selector="Button.choice">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.choice:pointerover">
            <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        </Style>
        <Style Selector="Button.choice.active">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        </Style>





        <!-- StepBorder Default -->
        <Style Selector="Border#StepBorder">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Border#StepBorder.active">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
        </Style>

        <!-- StepTitleText Default -->
        <Style Selector="TextBlock#StepTitleText">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>
        <Style Selector="Border#StepBorder.active TextBlock#StepTitleText">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- StepNumberCircle Default -->
        <Style Selector="Border#StepNumberCircle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="CornerRadius" Value="9"/>
        </Style>
        <Style Selector="Border#StepBorder.active Border#StepNumberCircle">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- StepNumberText Default -->
        <Style Selector="TextBlock#StepNumberText">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
        <Style Selector="Border#StepBorder.active TextBlock#StepNumberText">
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
        </Style>

        <!-- Completed Step Styling -->
        <Style Selector="Border#StepBorder.completed Border#StepNumberCircle">
            <Setter Property="BorderBrush" Value="{DynamicResource StatusOk}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Border#StepBorder.completed TextBlock#StepNumberText">
            <Setter Property="Foreground" Value="{DynamicResource StatusOk}"/>
        </Style>
        <Style Selector="Border#StepBorder.completed.active Border#StepNumberCircle">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Border#StepBorder.completed.active TextBlock#StepNumberText">
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
        </Style>

        <!-- Standard Card Style -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
        
        <!-- Typography -->
        <Style Selector="TextBlock.card-title">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="TextBlock.card-value">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style Selector="TextBlock.card-sub">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="6,12,6,6"/>
        </Style>

        <!-- New Unified Control Styles -->
        <!-- ComboBox Style -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        </Style>

        <!-- TextBox Style -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverColor}"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
        </Style>

        <!-- NumericUpDown Style -->
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="NumericUpDown:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        </Style>

        <!-- CheckBox Style -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ToggleSwitch Style -->
        <Style Selector="ToggleSwitch">
            <Setter Property="OnContent" Value=""/>
            <Setter Property="OffContent" Value=""/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Slider Style -->
        <Style Selector="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- TreeView Style -->
        <Style Selector="TreeView">
            <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <!-- Sidebar Section Title -->
        <Style Selector="TextBlock.sidebar-title">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LetterSpacing" Value="1"/>
        </Style>

        <!-- Card Section Header -->
        <Style Selector="TextBlock.card-header">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Styles>

    <Grid Background="Transparent">
        <!-- Dedicated drag surface for the extended client title area. Keep the right side clear for native window buttons. -->
        <Border Height="44"
                Margin="0,0,138,0"
                VerticalAlignment="Top"
                Background="Transparent"
                ZIndex="100"
                PointerPressed="Header_PointerPressed" />

        <Grid ColumnDefinitions="260,*" Background="Transparent">
        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" 
                Background="{DynamicResource SidebarBackground}" 
                BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="0,0,1,0" 
                Padding="16,40,16,16">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                <!-- App Logo & Title -->
                <StackPanel Grid.Row="0" Margin="0,10,0,24" Spacing="8" Orientation="Horizontal" VerticalAlignment="Center" Background="Transparent" PointerPressed="Header_PointerPressed">
                    <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                    <TextBlock Text="ODrive Control" 
                               Foreground="{DynamicResource TextPrimary}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                    <Border CornerRadius="4" Background="{DynamicResource ControlBackground}" Padding="4,2" Margin="4,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v2.0" FontSize="10" Foreground="{DynamicResource TextSecondary}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Device Selector Section -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20" Spacing="8">
                    <TextBlock Text="设备连接" Classes="sidebar-title"/>
                    <ComboBox ItemsSource="{Binding Devices}"
                              SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                              PlaceholderText="选择设备...">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimary}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,4,0,0">
                        <Button Grid.Column="0" Content="重新扫描" Command="{Binding RefreshDevicesCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="连接设备" Command="{Binding ConnectSelectedDeviceCommand}" Classes="primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Row="2" Spacing="4">
                    <TextBlock Text="导航菜单" Classes="sidebar-title" Margin="0,0,0,8"/>
                    
                    <Button Classes="nav" Classes.active="{Binding IsDashboardActive}" Command="{Binding SetTabCommand}" CommandParameter="Dashboard">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{Binding IconDashboard}" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="实时遥测" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav" Classes.active="{Binding IsControlActive}" Command="{Binding SetTabCommand}" CommandParameter="Control">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{Binding IconControl}" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="控制模式" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav" Classes.active="{Binding IsMotorActive}" Command="{Binding SetTabCommand}" CommandParameter="Motor">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{Binding IconMotor}" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="电机与标定" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav" Classes.active="{Binding IsEncoderActive}" Command="{Binding SetTabCommand}" CommandParameter="Encoder">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{Binding IconEncoder}" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="编码器反馈" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav" Classes.active="{Binding IsSystemActive}" Command="{Binding SetTabCommand}" CommandParameter="System">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{Binding IconSystem}" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="固件与 Schema" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav" Classes.active="{Binding IsGuideActive}" Command="{Binding SetTabCommand}" CommandParameter="Guide">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{Binding IconGuide}" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="设置指引" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer with Theme Toggle & Status -->
                <StackPanel Grid.Row="3" Spacing="10" Margin="0,20,0,0">
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <!-- Left: Status monitoring -->
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="状态监控" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ConnectionStatus}" Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Right: Clean Theme Toggle Button (Icon-Only) -->
                            <Button Grid.Column="1" Command="{Binding ToggleThemeCommand}" 
                                    Width="32" Height="32" CornerRadius="16" Padding="0"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    ToolTip.Tip="切换主题">
                                <PathIcon Data="{Binding CurrentThemeIcon}" Width="14" Height="14"/>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT WORKSPACE AREA -->
        <Border Grid.Column="1" Background="{DynamicResource PrimaryBackground}" Padding="24,0,24,24">
            <Grid RowDefinitions="70,*">
            <!-- HEADER -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" VerticalAlignment="Bottom" Margin="0,0,0,10" Background="Transparent" PointerPressed="Header_PointerPressed">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedTabTitle}" 
                               Foreground="{DynamicResource TextPrimary}" 
                               FontSize="22" 
                               FontWeight="Bold"/>
                    <Border CornerRadius="10" Background="{DynamicResource ControlBackground}" Padding="8,3" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource StatusOk}" VerticalAlignment="Center"/>
                            <TextBlock Text="串口驱动在线" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Quick actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,100,0">
                    <!-- Margin leaves space for window control buttons -->
                </StackPanel>
            </Grid>

            <!-- MAIN PANELS -->
            <Border Grid.Row="1" 
                    Background="{DynamicResource PanelBackground}" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="16">
                <Grid>
                    <!-- ======================================= -->
                    <!-- 1. DASHBOARD PANEL -->
                    <!-- ======================================= -->
                    <ScrollViewer IsVisible="{Binding IsDashboardActive}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="系统关键状态指标" Classes="section-title"/>
                            
                            <!-- Card Grid -->
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                                <Border Grid.Row="0" Grid.Column="0" Classes="card">
                                    <StackPanel>
                                        <TextBlock Text="母线电压 (VBUS)" Classes="card-title"/>
                                        <TextBlock Text="{Binding VbusVoltageText}" Classes="card-value"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="1" Classes="card">
                                    <StackPanel>
                                        <TextBlock Text="母线电流 (I_BUS)" Classes="card-title"/>
                                        <TextBlock Text="{Binding IbusText}" Classes="card-value"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="2" Classes="card">
                                    <StackPanel>
                                        <TextBlock Text="编码器位置估算" Classes="card-title"/>
                                        <TextBlock Text="{Binding EncoderPositionText}" Classes="card-value"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="0" Classes="card">
                                    <StackPanel>
                                        <TextBlock Text="编码器速度估算" Classes="card-title"/>
                                        <TextBlock Text="{Binding EncoderVelocityRpmText}" Classes="card-value"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Classes="card">
                                    <StackPanel>
                                        <TextBlock Text="多摩川通信 CRC 错误" Classes="card-title"/>
                                        <TextBlock Text="{Binding TamagawaCrcErrorCountText}" Classes="card-value" Foreground="{DynamicResource StatusOk}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="2" Classes="card">
                                    <StackPanel>
                                        <TextBlock Text="控制器循环状态" Classes="card-title"/>
                                        <TextBlock Text="{Binding ControllerLoopStatus}" Classes="card-value" Foreground="{DynamicResource StatusOk}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock Text="母线电压与电流趋势" Classes="section-title" Margin="6,18,6,6"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <Border Grid.Column="0" Classes="card">
                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="电机母线电压 (VBUS)" Classes="card-header"/>
                                            <TextBlock Text="最近约 30 秒 · 悬停时冻结曲线查看采样值" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                        </StackPanel>
                                        <controls:TelemetryTrendChart Grid.Row="1"
                                                                      Height="210"
                                                                      Samples="{Binding BusVoltageHistory}"
                                                                      LineBrush="{DynamicResource AccentColor}"
                                                                      GridBrush="{DynamicResource BorderBrush}"
                                                                      HoverBrush="{DynamicResource TextPrimary}"/>
                                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{Binding BusVoltageRangeText}" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding VbusVoltageText}" Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas" FontWeight="SemiBold"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Classes="card">
                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="双轴电机母线电流 (I_BUS)" Classes="card-header"/>
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource ChartAxis0Color}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Axis 0" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource ChartAxis1Color}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Axis 1" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                                </StackPanel>
                                                <TextBlock Text="· 悬停时冻结曲线查看采样值" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <controls:TelemetryTrendChart Grid.Row="1"
                                                                      Height="210"
                                                                      Samples="{Binding Axis0BusCurrentHistory}"
                                                                      SecondarySamples="{Binding Axis1BusCurrentHistory}"
                                                                      PrimaryLabel="Axis 0"
                                                                      SecondaryLabel="Axis 1"
                                                                      LineBrush="{DynamicResource ChartAxis0Color}"
                                                                      SecondaryLineBrush="{DynamicResource ChartAxis1Color}"
                                                                      GridBrush="{DynamicResource BorderBrush}"
                                                                      HoverBrush="{DynamicResource TextPrimary}"/>
                                        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <Grid Grid.Column="0" ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Axis0BusCurrentRangeText}" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Axis0BusCurrentText}" Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Grid Grid.Column="1" ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Axis1BusCurrentRangeText}" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Axis1BusCurrentText}" Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas" FontWeight="SemiBold"/>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ======================================= -->
                    <!-- 2. CONTROL PANEL -->
                    <!-- ======================================= -->
                    <ScrollViewer IsVisible="{Binding IsControlActive}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="控制模式、目标给定与轴状态" Classes="section-title"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <Border Grid.Column="0" Classes="card">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Axis Operation" Classes="card-header"/>
                                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>

                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <TextBlock Text="控制轴选择" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding AvailableAxes}"
                                                      SelectedItem="{Binding SelectedAxis, Mode=TwoWay}"
                                                      Width="92"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <TextBlock Text="闭环使能 (Closed Loop)" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsMotorEnabled}"/>
                                        </Grid>

                                        <StackPanel Spacing="6">
                                            <TextBlock Text="控制模式 (Control Mode)" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                            <ComboBox ItemsSource="{Binding AvailableControlModes}"
                                                      SelectedItem="{Binding ControlMode, Mode=TwoWay}"/>
                                        </StackPanel>

                                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,4,0,0">
                                            <Button Grid.Column="0" Content="Idle" Command="{Binding DisableMotorCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                            <Button Grid.Column="1" Content="清除错误" Command="{Binding ClearErrorsCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                            <Button Grid.Column="2" Content="紧急制动" Command="{Binding EmergencyStopCommand}" Classes="danger" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Classes="card">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="实时状态摘要" Classes="card-header"/>
                                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                            <TextBlock Text="Axis State" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding AxisStateText}" Foreground="{DynamicResource StatusOk}" FontFamily="Consolas" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                            <TextBlock Text="Axis Error" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding AxisErrorText}" Foreground="{DynamicResource StatusWarning}" FontFamily="Consolas"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                            <TextBlock Text="Controller Error" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ControllerErrorText}" Foreground="{DynamicResource StatusWarning}" FontFamily="Consolas"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                            <TextBlock Text="Bus Current (I_BUS)" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding IbusText}" Foreground="{DynamicResource AccentColor}" FontFamily="Consolas" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                            <TextBlock Text="Encoder Position" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding EncoderPositionText}" Foreground="{DynamicResource AccentColor}" FontFamily="Consolas" FontWeight="SemiBold"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock Text="目标给定 (Setpoints)" Classes="section-title"/>
                            <Border Classes="card">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                    <StackPanel Grid.Column="0" Spacing="8" IsVisible="{Binding IsPositionMode}">
                                        <TextBlock Text="目标位置 (Turns)" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                        <TextBox Text="{Binding TargetPosition, Mode=TwoWay, StringFormat={}{0:F2}}"
                                                 TextAlignment="Right"
                                                 FontFamily="Consolas"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Spacing="8" IsVisible="{Binding IsVelocityMode}">
                                        <TextBlock Text="目标速度 (RPM)" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                        <TextBox Text="{Binding TargetVelocity, Mode=TwoWay, StringFormat={}{0:F1}}"
                                                 TextAlignment="Right"
                                                 FontFamily="Consolas"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Spacing="8" IsVisible="{Binding IsTorqueMode}">
                                        <TextBlock Text="目标力矩 (Nm)" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                        <TextBox Text="{Binding TargetTorque, Mode=TwoWay, StringFormat={}{0:F2}}"
                                                 TextAlignment="Right"
                                                 FontFamily="Consolas"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="发送设置"
                                            Command="{Binding SendTargetCommand}"
                                            Classes="primary"
                                            Padding="18,8"
                                            VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>

                            <Border Classes="card">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <TextBlock Grid.Column="0" Text="最近执行命令反馈" Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LastCommandResult}" Foreground="{DynamicResource StatusOk}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ======================================= -->
                    <!-- 3. MOTOR PANEL -->
                    <!-- ======================================= -->
                    <ScrollViewer IsVisible="{Binding IsMotorActive}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="电机状态、调参与标定" Classes="section-title"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <StackPanel Grid.Column="0" Spacing="16">
                                    <Border Classes="card">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="Motor Runtime" Classes="card-header"/>
                                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="Motor Error" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding MotorErrorText}" Foreground="{DynamicResource StatusWarning}" FontFamily="Consolas"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="Armed" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding MotorArmedText}" Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="Calibration" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding MotorCalibratedText}" Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="Selected Axis I_BUS" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedAxisBusCurrentText}" Foreground="{DynamicResource AccentColor}" FontFamily="Consolas" FontWeight="SemiBold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <Border Grid.Column="0" Classes="card">
                                            <StackPanel>
                                                <TextBlock Text="电机温度" Classes="card-title"/>
                                                <TextBlock Text="{Binding MotorTemperatureText}" Classes="card-value"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Classes="card">
                                            <StackPanel>
                                                <TextBlock Text="FET 温度" Classes="card-title"/>
                                                <TextBlock Text="{Binding FetTemperatureText}" Classes="card-value"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="16">
                                    <Border Classes="card">
                                        <StackPanel Spacing="14">
                                            <TextBlock Text="PID / Control Loop Tuning" Classes="card-header"/>
                                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>

                                            <StackPanel Spacing="6">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="位置环比例增益 (pos_gain)" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding PosGain}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                                                </Grid>
                                                <NumericUpDown Value="{Binding PosGain}" Minimum="0" Maximum="100" Increment="1"/>
                                            </StackPanel>

                                            <StackPanel Spacing="6">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="速度环比例增益 (vel_gain)" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding VelGain, StringFormat={}{0:F6}}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                                                </Grid>
                                                <NumericUpDown Value="{Binding VelGain}" Minimum="0" Maximum="0.1" Increment="0.0001" FormatString="0.######"/>
                                            </StackPanel>

                                            <StackPanel Spacing="6">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="速度积分增益 (vel_integrator_gain)" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding VelIntegratorGain, StringFormat={}{0:F6}}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                                                </Grid>
                                                <NumericUpDown Value="{Binding VelIntegratorGain}" Minimum="0" Maximum="0.1" Increment="0.0001" FormatString="0.######"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="card">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="制动电阻 (Brake Resistor)" Classes="card-header"/>
                                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>

                                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="启用制动电阻" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="启用状态变更后需重启设备；出现错误时可清除错误后重试。" Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <ToggleSwitch Grid.Column="1" IsChecked="{Binding BrakeResistorEnabled}"/>
                                            </Grid>

                                            <StackPanel Spacing="6">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="制动电阻阻值 (brake_resistance)" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding BrakeResistance, StringFormat={}{0:0.###} Ω}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                                                </Grid>
                                                <NumericUpDown Value="{Binding BrakeResistance}" Minimum="0.001" Maximum="1000" Increment="0.1" FormatString="0.###"/>
                                            </StackPanel>

                                            <StackPanel Spacing="6">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="最大回馈电流 (max_regen_current)" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding MaxRegenCurrent, StringFormat={}{0:0.###} A}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                                                </Grid>
                                                <NumericUpDown Value="{Binding MaxRegenCurrent}" Minimum="-200" Maximum="0" Increment="0.1" FormatString="0.###"/>
                                            </StackPanel>

                                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>
                                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="母线过压斜坡保护（实验性）" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="母线电压升高时额外增加制动电阻占空比。" Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <ToggleSwitch Grid.Column="1" IsChecked="{Binding DcBusOvervoltageRampEnabled}"/>
                                            </Grid>

                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                <StackPanel Grid.Column="0" Spacing="6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="斜坡起始电压" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding DcBusOvervoltageRampStart, StringFormat={}{0:0.##} V}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                                                    </Grid>
                                                    <NumericUpDown Value="{Binding DcBusOvervoltageRampStart}" Minimum="0" Maximum="100" Increment="0.1" FormatString="0.##"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="斜坡终止电压" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding DcBusOvervoltageRampEnd, StringFormat={}{0:0.##} V}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
                                                    </Grid>
                                                    <NumericUpDown Value="{Binding DcBusOvervoltageRampEnd}" Minimum="0" Maximum="100" Increment="0.1" FormatString="0.##"/>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="终止电压必须高于起始电压，且低于硬件允许的过压跳闸值；起始电压不要低于平时母线电压。" Foreground="{DynamicResource StatusWarning}" FontSize="11" TextWrapping="Wrap"/>
                                            <TextBlock Text="请按实际接入的阻值填写；未接入制动电阻时不要启用，避免损坏电源。修改后请保存配置。" Foreground="{DynamicResource StatusWarning}" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="card" Background="{DynamicResource SidebarBackground}">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="电机标定与保存" Classes="card-header"/>
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Button Grid.Column="0" Content="执行电机标定" Command="{Binding CalibrateMotorCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                                <Button Grid.Column="1" Content="保存配置" Command="{Binding SaveConfigurationCommand}" Classes="warning" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="card" Height="96">
                                        <ScrollViewer>
                                            <TextBlock Text="{Binding LastCommandResult}" Foreground="{DynamicResource TextSecondary}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ======================================= -->
                    <!-- 4. ENCODER PANEL -->
                    <!-- ======================================= -->
                    <ScrollViewer IsVisible="{Binding IsEncoderActive}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="编码器反馈、状态与多摩川调测" Classes="section-title"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <StackPanel Grid.Column="0" Spacing="16">
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                                        <Border Grid.Row="0" Grid.Column="0" Classes="card">
                                            <StackPanel>
                                                <TextBlock Text="位置估算" Classes="card-title"/>
                                                <TextBlock Text="{Binding EncoderPositionText}" Classes="card-value"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1" Classes="card">
                                            <StackPanel>
                                                <TextBlock Text="速度估算" Classes="card-title"/>
                                                <TextBlock Text="{Binding EncoderVelocityRpmText}" Classes="card-value"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="0" Classes="card">
                                            <StackPanel>
                                                <TextBlock Text="Shadow Count" Classes="card-title"/>
                                                <TextBlock Text="{Binding EncoderShadowCountText}" Classes="card-value"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" Classes="card">
                                            <StackPanel>
                                                <TextBlock Text="Count In CPR" Classes="card-title"/>
                                                <TextBlock Text="{Binding EncoderCountInCprText}" Classes="card-value"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Classes="card">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="通用编码器状态" Classes="card-header"/>
                                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="Encoder Error" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding EncoderErrorText}" Foreground="{DynamicResource StatusWarning}" FontFamily="Consolas"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="Ready" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding EncoderReadyText}" Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="Index Found" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding EncoderIndexFoundText}" Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="16">
                                    <Border Classes="card">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="多摩川绝对值编码器" Classes="card-header"/>
                                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="报警状态 (Warning)" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding EncoderWarning}" Foreground="{DynamicResource StatusWarning}" FontWeight="Bold"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="通信错误 (Error)" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding EncoderError}" Foreground="{DynamicResource StatusOk}" FontWeight="Bold"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="CRC 错误计数" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TamagawaCrcErrorCountText}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="单圈绝对位置 (17-bit)" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TamagawaAbsolutePositionText}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                <TextBlock Text="多圈计数" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TamagawaMultiTurnText}" FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="card">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="编码器命令与调测" Classes="card-header"/>
                                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>
                                            <Button Content="多摩川运行自检命令" Command="{Binding RunTamagawaSelfTestCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                            <Button Content="清除编码器报警" Command="{Binding ClearEncoderWarningCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                            <Button Content="校准机械零点" Command="{Binding CalibrateEncoderZeroCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ======================================= -->
                    <!-- 5. SETUP GUIDE PANEL -->
                    <!-- ======================================= -->
                    <Grid RowDefinitions="Auto,Auto,Auto,*" IsVisible="{Binding IsGuideActive}">
                        <TextBlock Grid.Row="0" Text="ODrive 引导配置向导" Classes="section-title"/>

                        <!-- Breadcrumb Steps Navigation -->
                        <Border Grid.Row="1" Classes="card" Padding="16,12">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl Classes="breadcrumb" ItemsSource="{Binding SetupWizard.Steps}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- Step indicator -->
                                                <Border Name="StepBorder" Classes.active="{Binding IsActive}" Classes.completed="{Binding IsCompleted}" ToolTip.Tip="{Binding Title}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <Border Name="StepNumberCircle">
                                                            <TextBlock Name="StepNumberText" Text="{Binding StepNumber}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Name="StepTitleText" Text="{Binding Title}" IsVisible="{Binding IsActive}" FontSize="12" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Separator -->
                                                <TextBlock Name="StepSeparator" Text="›" Foreground="{DynamicResource TextSecondary}" IsVisible="{Binding ShowSeparator}" VerticalAlignment="Center" Margin="6,0" FontSize="14" FontWeight="Bold"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <!-- Navigation Controls Bar (Between Navigation and Step) -->
                        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Height="40" Margin="6,0">
                            <!-- Back Button -->
                            <Button Grid.Column="0" Command="{Binding SetupWizard.BackCommand}" 
                                    Width="46" Height="30" CornerRadius="6" Padding="0"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    ToolTip.Tip="上一步">
                                <PathIcon Width="12" Height="12" Data="{Binding IconChevronLeft}"/>
                            </Button>
                            
                            <!-- Status Text -->
                            <TextBlock Grid.Column="1" Text="{Binding SetupWizard.StatusText}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="13"/>
                            
                            <!-- Next Button -->
                            <Button Grid.Column="2" Command="{Binding SetupWizard.NextCommand}" IsVisible="{Binding SetupWizard.IsNotReviewStep}" 
                                    Classes="primary" Width="46" Height="30" CornerRadius="6" Padding="0"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    ToolTip.Tip="下一步">
                                <PathIcon Width="12" Height="12" Data="{Binding IconChevronRight}"/>
                            </Button>
                        </Grid>

                        <!-- Step Configuration Details (Takes Full Remaining Height) -->
                        <Grid Grid.Row="3" Margin="0,6,0,0">
                            <!-- Configuration Step Card -->
                            <Border Classes="card" IsVisible="{Binding SetupWizard.IsNotReviewStep}" VerticalAlignment="Stretch">
                                <Grid RowDefinitions="Auto,*">
                                    <!-- Fixed Card Header -->
                                    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,12">
                                        <TextBlock Text="{Binding SetupWizard.CurrentStep.Title}" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SetupWizard.CurrentStep.Description}" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" FontSize="13"/>
                                    </StackPanel>

                                    <!-- Scrollable content area inside step card -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="16" Margin="0,0,12,0">
                                            <ItemsControl ItemsSource="{Binding SetupWizard.CurrentStep.Choices}" IsVisible="{Binding SetupWizard.CurrentStep.HasChoices}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1" Margin="-6,0"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Classes="choice" Classes.active="{Binding IsSelected}"
                                                                Command="{Binding DataContext.SetupWizard.SelectChoiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Margin="6,4">
                                                            <Grid RowDefinitions="Auto,*" Margin="2">
                                                                <!-- Selected Indicator -->
                                                                <PathIcon Grid.Row="0" Width="10" Height="10" Data="M 13.5 4.5 L 6.5 11.5 L 2.5 7.5 L 4 6 L 6.5 8.5 L 12 3 Z" Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Right" VerticalAlignment="Top" IsVisible="{Binding IsSelected}"/>
                                                                
                                                                <!-- Text content -->
                                                                <StackPanel Grid.Row="1" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,4,4,0">
                                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Border Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" IsVisible="{Binding SetupWizard.CurrentStep.HasInputs}">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="本步骤输入" Classes="card-header"/>
                                                    <ItemsControl ItemsSource="{Binding SetupWizard.CurrentStep.Inputs}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="4" Margin="0,0,0,10">
                                                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Spacing="2">
                                                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="12"/>
                                                                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Value, Mode=TwoWay}"/>
                                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Path}" Foreground="{DynamicResource TextMuted}" FontFamily="Consolas" FontSize="11"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" IsVisible="{Binding SetupWizard.CurrentStep.HasCalibration}">
                                                <Button Content="请求电机标定" Command="{Binding SetupWizard.CalibrateMotorCommand}" IsVisible="{Binding SetupWizard.CurrentStep.HasMotorCalibration}" Padding="20,10" HorizontalContentAlignment="Center"/>
                                                <Button Content="请求编码器标定" Command="{Binding SetupWizard.CalibrateEncoderCommand}" IsVisible="{Binding SetupWizard.CurrentStep.HasEncoderCalibration}" Padding="20,10" HorizontalContentAlignment="Center"/>
                                            </StackPanel>

                                            <Border Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" IsVisible="{Binding SetupWizard.CurrentStep.HasCalibration}">
                                                <TextBlock Text="标定会让电机转动。执行前请固定电机与负载、确认电源与限流设置，并保证急停可用。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" FontSize="12"/>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <!-- Review Step Card -->
                            <Border Classes="card" IsVisible="{Binding SetupWizard.IsReviewStep}" VerticalAlignment="Stretch">
                                <Grid RowDefinitions="Auto,*,Auto">
                                    <!-- Fixed Card Header -->
                                    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,12">
                                        <TextBlock Text="复核并写入" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold"/>
                                        <TextBlock Text="核对配置参数。写入临时生效，保存配置后断电不丢失。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" FontSize="13"/>
                                    </StackPanel>

                                    <!-- Scrollable parameter table -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <Border Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,12,0">
                                            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                                                <Grid Grid.Row="0" ColumnDefinitions="2*,*,*,140" ColumnSpacing="12">
                                                    <TextBlock Text="参数路径" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="当前值" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Grid.Column="2" Text="新值" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Grid.Column="3" Text="状态" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
                                                </Grid>
                                                <ItemsControl Grid.Row="1" ItemsSource="{Binding SetupWizard.DraftEntries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnDefinitions="2*,*,*,140" ColumnSpacing="12" Margin="0,4">
                                                                <TextBlock Text="{Binding Path}" Foreground="{DynamicResource AccentColor}" FontFamily="Consolas" TextWrapping="Wrap" FontSize="12"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding CurrentValue}" Foreground="{DynamicResource TextSecondary}" FontFamily="Consolas" TextWrapping="Wrap" FontSize="12"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding NewValueText}" Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas" FontWeight="SemiBold" TextWrapping="Wrap" FontSize="12"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding Status}" Foreground="{DynamicResource StatusWarning}" TextWrapping="Wrap" FontSize="12"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </Border>
                                    </ScrollViewer>

                                    <!-- Fixed bottom actions bar -->
                                    <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,12,0,0">
                                        <Button Grid.Column="0" Content="重新读取当前值" Command="{Binding SetupWizard.RefreshCurrentValuesCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Apply 写入设备" Command="{Binding SetupWizard.ApplyDraftCommand}" Classes="primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                        <Button Grid.Column="2" Content="保存配置至闪存" Command="{Binding SetupWizard.SaveConfigurationCommand}" Classes="warning" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ======================================= -->
                    <!-- 6. SYSTEM PANEL -->
                    <!-- ======================================= -->
                    <ScrollViewer IsVisible="{Binding IsSystemActive}">
                        <StackPanel Spacing="16">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center" Margin="0,0,0,12">
                                <TextBlock Grid.Column="0" Text="ODrive 自定义固件接口规范 (Schema)" Classes="section-title" VerticalAlignment="Center" Margin="0"/>
                                <Button Grid.Column="1" Content="保存配置至闪存" Command="{Binding SaveConfigurationCommand}" Classes="warning" Padding="14,6" FontSize="12" VerticalAlignment="Center"/>
                            </Grid>
                            
                            <Grid ColumnDefinitions="*,360" ColumnSpacing="16">
                                    <Border Grid.Column="0" Classes="card">
                                        <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
                                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                                <TextBlock Text="参数树 (Read / Write)" Classes="card-header" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="读取选中分支" Command="{Binding ReadAllParametersCommand}" Padding="10,4" FontSize="12"/>
                                            </Grid>
                                            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding ParameterSearchText, Mode=TwoWay}"
                                                         PlaceholderText="搜索参数路径 / 描述，例如 encoder、pos_gain、tamagawa"/>
                                                <CheckBox Grid.Column="1"
                                                          Content="只看可写"
                                                          IsChecked="{Binding ShowWritableOnly}"/>
                                            </Grid>
                                            <TextBlock Grid.Row="2" Text="{Binding ParameterStatus}" Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap"/>

                                            <TreeView Grid.Row="3"
                                                      ItemsSource="{Binding ParameterTree}"
                                                      SelectedItem="{Binding SelectedParameterNode, Mode=TwoWay}"
                                                      Height="480">
                                                <TreeView.ItemTemplate>
                                                    <TreeDataTemplate ItemsSource="{Binding Children}">
                                                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontFamily="Consolas"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding CurrentValue}" Foreground="{DynamicResource AccentColor}" FontFamily="Consolas" Margin="10,0,0,0"/>
                                                        </Grid>
                                                    </TreeDataTemplate>
                                                </TreeView.ItemTemplate>
                                            </TreeView>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" Classes="card" VerticalAlignment="Top">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                            <TextBlock Grid.Row="0" Text="参数详情" Classes="card-header"/>
                                            <TextBlock Grid.Row="1" Text="{Binding SelectedParameterNode.Path}" Foreground="{DynamicResource TextSecondary}" FontFamily="Consolas" TextWrapping="Wrap"/>
                                            
                                            <!-- Property Details List to prevent text overflow -->
                                            <StackPanel Grid.Row="2" Spacing="6" Margin="0,4">
                                                <Grid ColumnDefinitions="80,*">
                                                    <TextBlock Grid.Column="0" Text="数据类型:" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding SelectedParameterNode.ValueType}" Foreground="{DynamicResource TextSecondary}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="80,*">
                                                    <TextBlock Grid.Column="0" Text="物理单位:" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding SelectedParameterNode.Unit}" Foreground="{DynamicResource TextSecondary}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="80,*">
                                                    <TextBlock Grid.Column="0" Text="参数说明:" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding SelectedParameterNode.Description}" Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="80,*">
                                                    <TextBlock Grid.Column="0" Text="执行状态:" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding SelectedParameterNode.Status}" Foreground="{DynamicResource StatusOk}" FontSize="12" TextWrapping="Wrap"/>
                                                </Grid>
                                            </StackPanel>

                                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding SelectedParameterNode.PendingValue, Mode=TwoWay}"
                                                         PlaceholderText="写入值"/>
                                                <Button Grid.Column="1" Content="读取" Command="{Binding ReadSelectedParameterCommand}" Padding="14,8"/>
                                                <Button Grid.Column="2" Content="写入" Command="{Binding WriteSelectedParameterCommand}" Classes="primary" Padding="14,8"/>
                                            </Grid>
                                            <TextBlock Grid.Row="4" Text="只读参数会拒绝写入；写入成功后会自动回读。真实硬件写配置类参数前请确认电机安全状态。" Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        </Border>
        </Grid>

        <Border ZIndex="100"
                IsVisible="{Binding IsSaveConfirmationOpen}"
                Background="#99000000">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                <Border Classes="card" Width="640" MaxHeight="560" Padding="24" Background="{DynamicResource MainBackground}">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                        <StackPanel Grid.Row="0" Spacing="6">
                            <TextBlock Text="确认保存配置" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text="以下参数将在确认后写入设备，并保存至 ODrive 闪存。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                                <TextBlock Text="待保存参数" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <ScrollViewer Grid.Row="1" MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding PendingConfigurationChanges}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Foreground="{DynamicResource TextSecondary}" FontFamily="Consolas" FontSize="12" Margin="0,3" TextWrapping="Wrap"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="未检测到改动时仍会执行保存操作。" Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <Button Grid.Column="1" Content="取消" Command="{Binding CancelSaveConfigurationCommand}"/>
                            <Button Grid.Column="2" Content="确认写入并保存" Command="{Binding ConfirmSaveConfigurationCommand}" Classes="warning"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
